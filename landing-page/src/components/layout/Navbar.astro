---
import Container from '@/components/ui/Container.astro';
import { mainNavLinks } from '@/constants/navigation';
import Button from '@/components/ui/Button.astro';
---

<nav
  class="sticky top-0 z-50 w-full bg-surface/80 backdrop-blur-lg shadow-sm"
  aria-label="Navegación principal"
>
  <Container class="flex items-center justify-between py-4">
    <a
      href="/"
      class="text-headline-md font-extrabold tracking-tight text-primary"
      aria-label="Silent SOS — Inicio"
    >
      Silent SOS
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {
        mainNavLinks.map((link) => (
          <a
            href={link.href}
            class="text-label-md text-on-surface-variant transition-colors hover:text-primary"
          >
            {link.label}
          </a>
        ))
      }
      <Button href="#" variant="primary">Obtén Silent SOS</Button>
    </div>

    <details class="group relative md:hidden">
      <summary
        class="flex cursor-pointer list-none items-center justify-center rounded-lg p-2 text-deep-navy [&::-webkit-details-marker]:hidden"
        aria-label="Abrir menú de navegación"
      >
        <span class="material-symbols-outlined text-2xl group-open:hidden">menu</span>
        <span class="material-symbols-outlined hidden text-2xl group-open:inline">close</span>
      </summary>
      <div
        class="absolute right-0 top-full mt-2 min-w-[220px] rounded-xl border border-outline-variant/30 bg-surface-container-lowest p-4 shadow-xl"
        role="menu"
      >
        {
          mainNavLinks.map((link) => (
            <a
              href={link.href}
              class="block rounded-lg px-3 py-2 text-label-md text-on-surface-variant transition-colors hover:bg-surface-container hover:text-primary"
              role="menuitem"
            >
              {link.label}
            </a>
          ))
        }
        <div class="mt-3 border-t border-outline-variant/30 pt-3">
          <Button href="#" variant="primary" class="w-full">Obtén Silent SOS</Button>
        </div>
      </div>
    </details>
  </Container>
</nav>
