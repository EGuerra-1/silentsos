---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span
  class:list={[
    'inline-block rounded-full bg-secondary-container px-3 py-1 text-label-sm font-label-md uppercase tracking-wider text-on-secondary-container',
    className,
  ]}
>
  <slot />
</span>
