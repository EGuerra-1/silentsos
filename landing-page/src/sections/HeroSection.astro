---
import Container from '@/components/ui/Container.astro';
import Badge from '@/components/ui/Badge.astro';
import Icon from '@/components/ui/Icon.astro';
---

<section class="relative overflow-hidden pb-24 pt-stack-xl lg:pt-32" aria-labelledby="hero-heading">
  <Container class="grid grid-cols-1 items-center gap-8 lg:grid-cols-2 lg:gap-gutter">
    <div class="z-10">
      <Badge class="mb-6">Proyecto Comunitario Gratuito</Badge>
      <h1
        id="hero-heading"
        class="mb-6 text-display-lg-mobile font-extrabold leading-tight text-deep-navy md:text-display-lg"
      >
        Seguridad sin palabras.<br />
        Comunicación sin límites.
      </h1>
      <p class="mb-stack-lg max-w-xl text-body-lg text-on-surface-variant">
        La herramienta móvil de seguridad abierta, diseñada para la comunidad con
        discapacidad auditiva y del habla. Sin costos, para todos.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="#"
          class="inline-flex items-center gap-3 rounded-xl bg-deep-navy px-8 py-4 text-white shadow-lg transition-all hover:-translate-y-1 hover:shadow-xl active:scale-95"
          aria-label="Descargar en App Store — próximamente"
        >
          <Icon name="apps" filled class="text-2xl" />
          <div class="text-left">
            <p class="text-[10px] font-bold uppercase leading-none opacity-60">Descargar en la</p>
            <p class="text-lg font-bold leading-none">App Store</p>
          </div>
        </a>
        <a
          href="#"
          class="inline-flex items-center gap-3 rounded-xl border border-outline-variant bg-surface-container-highest px-8 py-4 text-deep-navy transition-all hover:-translate-y-1 hover:bg-surface-container active:scale-95"
          aria-label="Consíguelo en Google Play — próximamente"
        >
          <Icon name="play_arrow" filled class="text-2xl" />
          <div class="text-left">
            <p class="text-[10px] font-bold uppercase leading-none opacity-60">Consíguelo en</p>
            <p class="text-lg font-bold leading-none">Google Play</p>
          </div>
        </a>
      </div>
    </div>

    <div class="relative flex justify-center lg:justify-end lg:mt-0 mt-16">
      <div
        class="absolute -right-10 -top-10 h-64 w-64 rounded-full bg-secondary/10 blur-3xl"
        aria-hidden="true"
      ></div>
      <div
        class="relative h-[640px] w-[300px] overflow-hidden rounded-[3rem] border-[8px] border-deep-navy bg-white shadow-2xl"
        role="img"
        aria-label="Vista previa de la aplicación Silent SOS mostrando el centro de emergencias"
      >
        <div class="flex h-full w-full flex-col bg-slate-50">
          <div class="pb-4 pt-10 text-center">
            <p class="text-sm font-bold tracking-wide text-mockup-purple">Emergencias</p>
          </div>

          <div class="mockup-content flex min-h-0 flex-1 flex-col space-y-3 overflow-hidden px-4 pb-1">
            <div class="gradient-card relative rounded-3xl border border-white/50 p-4 shadow-sm">
              <div class="mb-2 flex items-start justify-between">
                <h2 class="w-3/4 text-xl font-bold leading-tight text-deep-navy">
                  Centro de emergencias
                </h2>
                <div class="rounded-xl bg-white/60 p-2">
                  <Icon name="shield" class="text-xl text-mockup-purple" />
                </div>
              </div>
              <p class="mb-4 text-xs leading-relaxed text-on-surface-variant/80">
                Activa ayuda inmediata o envía contexto visual con IA.
              </p>
              <div class="flex gap-2">
                <div class="flex items-center gap-1 rounded-full border border-blue-100 bg-white/80 px-3 py-1.5">
                  <Icon name="my_location" class="text-xs text-mockup-purple" />
                  <span class="text-[10px] font-bold text-mockup-purple">Ubicación lista</span>
                </div>
                <div class="flex items-center gap-1 rounded-full border border-blue-100 bg-white/80 px-3 py-1.5">
                  <Icon name="check_circle" class="text-xs text-mockup-purple" />
                  <span class="text-[10px] font-bold text-mockup-purple">Protección activa</span>
                </div>
              </div>
            </div>

            <div class="gradient-card relative overflow-hidden rounded-3xl border border-white/50 p-4 shadow-sm">
              <div class="flex items-center justify-between">
                <div class="w-2/3">
                  <h3 class="mb-1 text-sm font-bold text-deep-navy">SOS rápido</h3>
                  <p class="text-[10px] leading-tight text-on-surface-variant">
                    Alerta inmediata con ubicación precisa.
                  </p>
                </div>
                <div
                  class="sos-glow flex h-14 w-14 items-center justify-center rounded-full bg-sos-red text-white shadow-lg"
                  aria-hidden="true"
                >
                  <div class="text-center leading-[0.8]">
                    <p class="text-[10px] font-black">SOS</p>
                    <p class="text-[10px] font-black">SOS</p>
                  </div>
                </div>
              </div>
              <div class="mt-4 flex rounded-2xl bg-surface-container/50 p-1">
                <button
                  type="button"
                  class="flex flex-1 items-center justify-center gap-2 rounded-xl bg-mockup-purple py-3 text-white"
                  tabindex="-1"
                  aria-hidden="true"
                >
                  <Icon name="medical_services" class="text-sm" />
                  <span class="text-xs font-bold">Médica</span>
                </button>
                <button
                  type="button"
                  class="flex flex-1 items-center justify-center gap-2 rounded-xl py-3 text-on-surface-variant"
                  tabindex="-1"
                  aria-hidden="true"
                >
                  <Icon name="report" class="text-sm" />
                  <span class="text-xs font-bold">General</span>
                </button>
              </div>
            </div>

            <div class="flex items-center gap-3 rounded-3xl border border-blue-100/50 bg-blue-50/50 p-4">
              <div class="rounded-2xl border border-blue-50 bg-white p-3 shadow-sm">
                <Icon name="photo_camera" class="text-mockup-purple" />
              </div>
              <div class="flex-grow">
                <h3 class="text-xs font-bold text-deep-navy">Con contexto</h3>
                <p class="text-[10px] text-on-surface-variant">
                  Captura escena y rostro; la IA analiza y llama.
                </p>
              </div>
              <Icon name="arrow_forward" class="text-lg text-mockup-purple" />
            </div>

            <p class="px-2 pt-1 text-center text-[10px] leading-tight text-on-surface-variant/60">
              SOS arriba para alerta rápida. Abajo para emergencia con fotos.
            </p>
          </div>

          <div class="mt-auto flex items-center justify-between rounded-t-[2.5rem] border-t border-outline-variant/30 bg-white px-6 py-4">
            <div class="flex flex-col items-center gap-1">
              <div class="mb-1 flex h-6 w-12 items-center justify-center rounded-full bg-mockup-purple text-white">
                <Icon name="emergency_home" filled class="text-sm" />
              </div>
              <span class="text-[10px] font-bold text-mockup-purple">Emergencias</span>
            </div>
            <div class="flex flex-col items-center gap-1 opacity-60">
              <Icon name="medical_information" class="text-xl" />
              <span class="text-[10px] font-bold">Salud</span>
            </div>
            <div class="flex flex-col items-center gap-1 opacity-60">
              <Icon name="settings" class="text-xl" />
              <span class="text-[10px] font-bold">Ajustes</span>
            </div>
          </div>
          <div class="mx-auto mb-2 mt-1 h-1 w-32 rounded-full bg-surface-variant" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </Container>
</section>
