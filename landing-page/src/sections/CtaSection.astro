---
import Container from '@/components/ui/Container.astro';
import Button from '@/components/ui/Button.astro';
---

<section class="py-stack-xl" aria-labelledby="cta-heading">
  <Container class="text-center">
    <div class="relative overflow-hidden rounded-[3rem] bg-deep-navy px-8 py-16 text-white">
      <div class="relative z-10">
        <h2 id="cta-heading" class="mb-6 text-headline-xl">
          Herramientas libres para salvar vidas.
        </h2>
        <p class="mx-auto mb-10 max-w-xl text-body-lg opacity-80">
          Silent SOS es un proyecto comunitario gratuito. Únete a miles de usuarios que ya
          confían en nosotros para su tranquilidad diaria.
        </p>
        <Button href="#" variant="secondary" ariaLabel="Descargar Silent SOS — próximamente">
          Descargar
        </Button>
      </div>
    </div>
  </Container>
</section>
