# Archivo .env.example para SilentSOS

# Configuración de la API
API_CONTAINER_NAME=api_ejemplo
API_PORT=4000

# Configuración de la Base de Datos
# DB_HOST=db dentro de Docker | 127.0.0.1 desde tu máquina
DB_CONTAINER_NAME=db_ejemplo
DB_HOST=127.0.0.1
DB_USER=usuario_demo
DB_PASSWORD=ClaveDemo123
DB_NAME=database_demo
DB_INTERNAL_PORT=5432
DB_EXTERNAL_PORT=5435
DB_PORT=5435

# Entorno de Ejecución
NODE_ENV=development

# Configuración de JWT para Autenticación
JWT_SECRET_ADMIN=AdminSecretExample_123456789
JWT_SECRET_USER=UserSecretExample_987654321
JWT_EXPIRES_IN_ADMIN=30d
JWT_EXPIRES_IN_USER=30d

# Configuración de CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://example.com

# --- OpenAI (triage visual) ---
OPENAI_API_KEY=sk-proj-your_openai_key_here
OPENAI_MODEL=gpt-4o
OPENAI_TRIAGE_TIMEOUT_MS=15000

# --- ElevenLabs (TTS + STT) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
ELEVENLABS_STT_MODEL=scribe_v2

# --- Zavu (mensajería SMS/WhatsApp) ---
ZAVU_API_KEY=zv_live_your_zavu_key_here
ZAVU_SENDER_ID=your_sender_id_here
ZAVU_DEFAULT_CHANNEL=sms

# --- n8n (workflow para enviar SMS por Zavu) ---
N8N_EMERGENCY_WEBHOOK_URL=https://your-n8n-domain/webhook/silentsos-emergency-sms
N8N_EMERGENCY_WEBHOOK_SECRET=your_optional_webhook_secret
N8N_WEBHOOK_TIMEOUT_MS=10000

# --- Twilio (llamadas de voz) ---
TWILIO_ACCOUNT_SID=ACyour_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- AWS S3 (media: imágenes, video, audio) ---
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=silentsos-media

# --- Backend público (webhooks Twilio/Zavu + TwiML) ---
PUBLIC_BASE_URL=https://your-ngrok-or-domain.com
EMERGENCY_PHONE_NUMBER=+503XXXXXXXX

# Almacenamiento local cuando S3 no está configurado (dev)
LOCAL_STORAGE_PATH=storage
